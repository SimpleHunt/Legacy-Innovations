generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductTable {
  id            Int  @id @default(autoincrement())
  productName   String
  productDes    String
  productType   String
  productSize   String
  climate       ClimateList
  tareena       String
  createdAt     DateTime @default(now())

}

enum ClimateList {
  Cool
  Warm
  Both
}
